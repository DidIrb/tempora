{
  "name": "tempora",
  "version": "1.0.0",
  "private": true,
  "description": "Tempora monorepo root",
  "scripts": {
    "prepare": "husky",
    "build": "npm --prefix packages/cli run build",
    "dev": "npm --prefix packages/cli run dev",
    "lint": "npm --prefix packages/cli run lint",
    "registry:build": "tsx scripts/buildRegistry.ts",
    "docs:sync": "tsx scripts/syncDocs.ts",
    "commit": "git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  }
}
