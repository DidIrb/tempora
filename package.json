{
  "name": "tempora",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Tempora monorepo root",
  "scripts": {
    "prepare": "husky",
    "build": "npm --prefix packages/cli run build && npm --prefix apps/docs run build",
    "dev": "npm --prefix packages/cli run dev",
    "docs:dev": "npm --prefix apps/docs run dev",
    "docs:build": "npm --prefix apps/docs run build",
    "lint": "npm --prefix packages/cli run lint",
    "commit": "git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.2.0",
      "@types/react-dom": "^18.2.0"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"],
    "rules": {
      "scope-empty": [0],
      "scope-case": [0]
    }
  }
}
